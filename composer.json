{
    "name": "coodex-es/laravel-editing-by",
    "description": "Track active editing ownership for Eloquent models.",
    "version": "1.1.0",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^8.1",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/events": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "CoodexEs\\LaravelEditingBy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CoodexEs\\LaravelEditingBy\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CoodexEs\\LaravelEditingBy\\LaravelEditingByServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
